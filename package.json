{
  "name": "cartograph",
  "version": "0.1.0",
  "description": "Map your codebase so AI can navigate it",
  "type": "module",
  "bin": {
    "cartograph": "./dist/cli/main.js"
  },
  "scripts": {
    "dev": "tsx src/cli/main.ts",
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run tests/integration",
    "migrate": "tsx src/db/migrate.ts",
    "setup": "./scripts/setup.sh",
    "db:export": "./scripts/db-export.sh",
    "db:import": "./scripts/db-import.sh"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/motawy/cartographer.git"
  },
  "overrides": {
    "tree-sitter-php": {
      "tree-sitter": "$tree-sitter"
    }
  },
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.8.0",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.5",
    "tree-sitter": "^0.25.0",
    "tree-sitter-php": "^0.24.2",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
